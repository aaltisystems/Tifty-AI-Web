# ==============================================================================
# Tifty AI — Variables de Entorno
# ==============================================================================
# Copia este archivo como .env y rellena con tus valores reales.
# ⚠️  NUNCA subas el archivo .env a repositorios públicos.
# Asegúrate de que .env está incluido en tu .gitignore.
# ==============================================================================

# --- Base de Datos ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tiftyai_db
DB_USER=
DB_PASSWORD=

# --- API Keys (Inteligencia Artificial) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Email / SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=contacto@tiftyai.com

# --- Integraciones Externas ---
HUBSPOT_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- Configuración del Servidor ---
PORT=3000
NODE_ENV=development
APP_URL=https://tiftyai.com

# --- Seguridad ---
JWT_SECRET=
SESSION_SECRET=
CORS_ALLOWED_ORIGINS=https://tiftyai.com
